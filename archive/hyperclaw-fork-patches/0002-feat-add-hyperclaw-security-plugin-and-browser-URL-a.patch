diff --git a/src/infra/browser-approvals.ts b/src/infra/browser-approvals.ts
new file mode 100644
index 0000000000..9a764066b6
--- /dev/null
+++ b/src/infra/browser-approvals.ts
@@ -0,0 +1,158 @@
+/**
+ * Browser URL approval allowlist — hyperclaw addition.
+ *
+ * Mirrors the exec-approvals allowlist pattern for URL-based access control.
+ * Allowlist entries are URL patterns matched against the hostname (and optionally path).
+ *
+ * File: ~/.openclaw/browser-approvals.json
+ */
+
+import crypto from "node:crypto";
+import fs from "node:fs";
+import path from "node:path";
+import { expandHomePrefix } from "./home-dir.js";
+
+const DEFAULT_FILE = "~/.openclaw/browser-approvals.json";
+
+export type BrowserAllowlistEntry = {
+  id?: string;
+  /** Hostname glob or URL prefix, e.g. "github.com", "*.google.com", "https://api.example.com/v1" */
+  pattern: string;
+  lastUsedAt?: number;
+  lastUsedUrl?: string;
+};
+
+export type BrowserApprovalsFile = {
+  version: 1;
+  entries?: BrowserAllowlistEntry[];
+};
+
+export function resolveBrowserApprovalsPath(): string {
+  return expandHomePrefix(DEFAULT_FILE);
+}
+
+export function loadBrowserApprovals(): BrowserApprovalsFile {
+  const filePath = resolveBrowserApprovalsPath();
+  try {
+    if (!fs.existsSync(filePath)) {
+      return { version: 1, entries: [] };
+    }
+    const raw = fs.readFileSync(filePath, "utf8");
+    const parsed = JSON.parse(raw) as BrowserApprovalsFile;
+    if (parsed?.version !== 1) {
+      return { version: 1, entries: [] };
+    }
+    return parsed;
+  } catch {
+    return { version: 1, entries: [] };
+  }
+}
+
+export function saveBrowserApprovals(file: BrowserApprovalsFile): void {
+  const filePath = resolveBrowserApprovalsPath();
+  const dir = path.dirname(filePath);
+  fs.mkdirSync(dir, { recursive: true });
+  fs.writeFileSync(filePath, `${JSON.stringify(file, null, 2)}\n`, { mode: 0o600 });
+  try {
+    fs.chmodSync(filePath, 0o600);
+  } catch {
+    // best-effort
+  }
+}
+
+/**
+ * Check if a URL is covered by any entry in the allowlist.
+ * Matching rules (checked in order):
+ *   1. Exact hostname match: pattern "github.com" matches https://github.com/anything
+ *   2. Wildcard subdomain: pattern "*.github.com" matches https://api.github.com/...
+ *   3. URL prefix: pattern "https://api.example.com/v1" matches any URL starting with it
+ */
+export function checkUrlAllowlist(url: string, entries: BrowserAllowlistEntry[]): boolean {
+  if (!entries || entries.length === 0) return false;
+  let hostname = "";
+  let fullUrl = url;
+  try {
+    const parsed = new URL(url);
+    hostname = parsed.hostname.toLowerCase();
+    fullUrl = url.toLowerCase();
+  } catch {
+    return false;
+  }
+  for (const entry of entries) {
+    const pattern = entry.pattern.trim().toLowerCase();
+    if (!pattern) continue;
+    // URL prefix match
+    if (pattern.startsWith("http://") || pattern.startsWith("https://")) {
+      if (fullUrl.startsWith(pattern)) return true;
+      continue;
+    }
+    // Wildcard subdomain: *.example.com
+    if (pattern.startsWith("*.")) {
+      const base = pattern.slice(2);
+      if (hostname === base || hostname.endsWith("." + base)) return true;
+      continue;
+    }
+    // Exact hostname match
+    if (hostname === pattern) return true;
+  }
+  return false;
+}
+
+/**
+ * Add a URL pattern (hostname) to the allowlist and save.
+ * Deduplicates by pattern.
+ */
+export function addUrlToAllowlist(
+  urlOrHostname: string,
+  file: BrowserApprovalsFile,
+  lastUsedUrl?: string,
+): void {
+  let pattern = urlOrHostname.trim().toLowerCase();
+  // If it looks like a full URL, extract the hostname
+  try {
+    if (pattern.startsWith("http://") || pattern.startsWith("https://")) {
+      pattern = new URL(pattern).hostname;
+    }
+  } catch {
+    // use as-is
+  }
+  if (!pattern) return;
+  const entries = Array.isArray(file.entries) ? file.entries : [];
+  if (entries.some((e) => e.pattern.trim().toLowerCase() === pattern)) return;
+  entries.push({
+    id: crypto.randomUUID(),
+    pattern,
+    lastUsedAt: Date.now(),
+    lastUsedUrl: lastUsedUrl?.trim() || undefined,
+  });
+  file.entries = entries;
+  saveBrowserApprovals(file);
+}
+
+/** Record that an allowlist entry was used (updates lastUsedAt + lastUsedUrl). */
+export function recordBrowserAllowlistUse(
+  file: BrowserApprovalsFile,
+  url: string,
+): void {
+  const hostname = (() => {
+    try {
+      return new URL(url).hostname.toLowerCase();
+    } catch {
+      return url.toLowerCase();
+    }
+  })();
+  const entries = Array.isArray(file.entries) ? file.entries : [];
+  let changed = false;
+  for (const entry of entries) {
+    const pattern = entry.pattern.trim().toLowerCase();
+    if (hostname === pattern || hostname.endsWith("." + pattern.replace(/^\*\./, ""))) {
+      entry.lastUsedAt = Date.now();
+      entry.lastUsedUrl = url;
+      changed = true;
+    }
+  }
+  if (changed) {
+    file.entries = entries;
+    saveBrowserApprovals(file);
+  }
+}
