+# Hyperclaw Secure Environment Configuration
+#
+# Copy to ~/.hyperclaw/.env and fill in your values.
+# Generate tokens with: openssl rand -hex 32
+#
+# SECURITY CHECKLIST:
+#   [ ] chmod 600 ~/.hyperclaw/.env
+#   [ ] Never commit this file to git
+#   [ ] Rotate HYPERCLAW_GATEWAY_TOKEN periodically
+
+# -----------------------------------------------------------------------------
+# Gateway Auth (REQUIRED)
+# -----------------------------------------------------------------------------
+# 256-bit random token - generate with: openssl rand -hex 32
+HYPERCLAW_GATEWAY_TOKEN=
+
+# -----------------------------------------------------------------------------
+# Model Provider API Keys (at least one required)
+# -----------------------------------------------------------------------------
+ANTHROPIC_API_KEY=
+# OPENAI_API_KEY=
+# GEMINI_API_KEY=
+
+# -----------------------------------------------------------------------------
+# Telegram (REQUIRED for human-in-the-loop approval)
+# -----------------------------------------------------------------------------
+# Create bot via @BotFather, get token
+TELEGRAM_BOT_TOKEN=
+
+# Your chat ID - send /start to @userinfobot to get it
+TELEGRAM_CHAT_ID=
+
+# -----------------------------------------------------------------------------
+# Docker Compose Paths
+# -----------------------------------------------------------------------------
+HYPERCLAW_IMAGE=hyperclaw:local
+HYPERCLAW_CONFIG_DIR=~/.hyperclaw
+HYPERCLAW_WORKSPACE_DIR=~/.hyperclaw/workspace
+HYPERCLAW_LOGS_DIR=~/.hyperclaw/logs
+HYPERCLAW_STATE_DIR=~/.hyperclaw/state
+
+# Gateway binding: loopback (localhost only) or lan (Tailscale/LAN access)
+HYPERCLAW_GATEWAY_BIND=loopback
+HYPERCLAW_GATEWAY_PORT=18789
+HYPERCLAW_BRIDGE_PORT=18790
+
+# -----------------------------------------------------------------------------
+# Hyperclaw-Security Plugin Config
+# -----------------------------------------------------------------------------
+# These are passed to the plugin via openclaw.json, not env vars.
+# See config/openclaw.json.example for plugin configuration.
